# ============================================================================
# MK Flow WhatsApp — variáveis de ambiente (frontend)
# ============================================================================
# Copie este arquivo para `.env` e preencha com as credenciais do seu projeto
# de backend (Lovable Cloud ou Supabase self-hosted). NUNCA commite `.env`.
#
# Como obter no Lovable Cloud:
#   Project Settings → Backend → Connection details
#
# Como obter num Supabase próprio (self-hosted / supabase.com):
#   Settings → API → Project URL  +  Project API keys → anon/public
# ============================================================================

# URL pública do projeto Supabase (ex.: https://xxxx.supabase.co)
VITE_SUPABASE_URL=

# Chave pública/anon — pode ir para o cliente, é protegida por RLS
VITE_SUPABASE_PUBLISHABLE_KEY=

# Project ref do Supabase (parte do subdomínio, ex.: xxxx)
VITE_SUPABASE_PROJECT_ID=

# ----------------------------------------------------------------------------
# Backend Node.js (Baileys) — opcional, só quando você implantar o backend real
# ----------------------------------------------------------------------------
# URL pública do backend que vai falar com o WhatsApp via Baileys.
# Ex.: https://api.seudominio.com
# VITE_WHATSAPP_BACKEND_URL=
